# =============================================================================
# Siraa.lk environment configuration
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# =============================================================================

# ----- Supabase -----
# Get these from https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-server-only

# ----- Cloudflare R2 (image storage) -----
# Create a bucket at https://dash.cloudflare.com → R2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=siraa-vehicle-images
R2_PUBLIC_URL=https://images.siraa.lk

# ----- SMSLenz (phone OTP) -----
# Get from https://smslenz.lk/dashboard
SMSLENZ_USER_ID=your-user-id
SMSLENZ_API_KEY=your-api-key
SMSLENZ_SENDER_ID=SiraaLK
# Use SMSlenzDEMO for testing; SiraaLK for production
SMSLENZ_BASE_URL=https://smslenz.lk/api

# ----- PayHere (payment gateway) -----
# Sandbox: https://sandbox.payhere.lk
# Production: https://www.payhere.lk
PAYHERE_MERCHANT_ID=your-merchant-id
PAYHERE_MERCHANT_SECRET=your-merchant-secret
PAYHERE_MODE=sandbox
# sandbox | live
NEXT_PUBLIC_PAYHERE_CHECKOUT_URL=https://sandbox.payhere.lk/pay/checkout

# ----- Cloudflare Turnstile (bot protection for OTP) -----
# Get from https://dash.cloudflare.com → Turnstile (free, no Pro tier needed)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-site-key
TURNSTILE_SECRET_KEY=your-secret-key

# ----- Session secret (32+ chars random string for JWT signing) -----
# Generate one: openssl rand -base64 48
SESSION_SECRET=replace-with-a-random-string-at-least-32-chars-long

# ----- Cron secret (random string for protecting cron endpoints) -----
# Used as: Authorization: Bearer <CRON_SECRET>
# Vercel Cron auto-supplies this via user-agent header in production.
# Generate one: openssl rand -base64 32
CRON_SECRET=replace-with-a-random-string

# ----- Google services -----
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ----- App config -----
NEXT_PUBLIC_SITE_URL=https://siraa.lk
NODE_ENV=development

# ----- Admin auth seed -----
# Used once to bootstrap the first super-admin via SQL seed
SEED_ADMIN_PHONE=+9476XXXXXXX
SEED_ADMIN_NAME=Bathi
