{
  "name": "siraa-lk",
  "version": "0.1.0",
  "private": true,
  "description": "Sri Lankan vehicle marketplace — fast, SEO-first, mobile-first. Open source.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/siraa-lk-vehicle-selling-platform-sri-lanka"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "db:types": "supabase gen types typescript --local > types/database.ts",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:diff": "supabase db diff",
    "prepare": "husky || true"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "@supabase/supabase-js": "^2.45.0",
    "@supabase/ssr": "^0.5.0",
    "zod": "^3.23.0",
    "@marsidev/react-turnstile": "^1.1.0",
    "jose": "^5.9.0",
    "lucide-react": "^0.460.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "sharp": "^0.33.5",
    "bcryptjs": "^2.4.3",
    "date-fns": "^4.1.0",
    "nanoid": "^5.0.0",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.14",
    "tailwindcss": "^3.4.14",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "supabase": "^1.215.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,sql}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
